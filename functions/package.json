{
 "name": "commandops-backend-functions",
 "version": "0.1.0",
 "private": true,
 "main": "lib/index.js",
 "engines": {
  "node": "20"
 },
 "scripts": {
  "build": "tsc",
  "build:watch": "tsc --watch",
  "dev:flow": "tsx src/dev/runEmulatorFlow.ts",
  "clean": "rimraf lib",
  "serve": "npm run build && firebase emulators:start --only functions",
  "shell": "npm run build && firebase functions:shell",
  "deploy": "firebase deploy --only functions",
  "lint": "echo \"Add eslint later\""
 },
 "dependencies": {
  "firebase": "^12.10.0",
  "firebase-admin": "^12.7.0",
  "firebase-functions": "^6.1.1",
  "zod": "^3.24.1"
 },
 "devDependencies": {
  "@types/node": "^22.10.2",
  "rimraf": "^6.0.1",
  "tsx": "^4.21.0",
  "typescript": "^5.7.2"
 }
}
